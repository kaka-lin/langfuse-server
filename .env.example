# ==========================================
# 1. 系統通用與存取設定 (System & Access)
# ==========================================

# 整個系統容器的時區，預設為台北
TZ=Asia/Taipei

# 外部存取網址，如果是本機開發請維持 localhost
LANGFUSE_PUBLIC_URL=http://localhost:3000

# Web 服務對外開放的連接埠
LANGFUSE_PORT=3000

# ==========================================
# 2. 安全加密金鑰 (Security Secrets - 重要！)
# ==========================================

# 用於加密瀏覽器端 Session Cookies (建議 64 字符隨機字串)
NEXTAUTH_SECRET=replace_with_a_long_random_string

# 用於系統資料加鹽雜湊
LANGFUSE_SALT=replace_with_a_long_random_string

# 用於加密存放在資料庫中的敏感資訊 (如 API Keys)
LANGFUSE_ENCRYPTION_KEY=replace_with_a_62_char_random_string

# ==========================================
# 3. PostgreSQL (核心/關聯式資料庫)
# ==========================================
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse_password
POSTGRES_DB=langfuse
POSTGRES_PORT=5432

# ==========================================
# 4. ClickHouse (分析型/列式資料庫)
# ==========================================
CLICKHOUSE_DB=langfuse
CLICKHOUSE_USER=langfuse
CLICKHOUSE_PASSWORD=langfuse_password
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000

# 是否啟用 ClickHouse 叢集模式 (單機部署請設為 false)
CLICKHOUSE_CLUSTER_ENABLED=false

# ==========================================
# 5. Redis (快取與任務佇列)
# ==========================================
REDIS_PORT=6379

# ==========================================
# 6. MinIO / S3 物件儲存 (Langfuse V3 強制要求)
# ==========================================

# 用來存放 Traces 中的圖片、附件或大型 payload
# MinIO 帳號需至少 3 位，密碼需至少 8 位
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=replace_with_a_secure_password_at_least_8_chars

# ==========================================
# 7. 初始環境設定 (僅在首次啟動時生效)
# ==========================================
LANGFUSE_INIT_ORG_ID=personal-org
LANGFUSE_INIT_ORG_NAME="My Organization"
LANGFUSE_INIT_PROJECT_ID=default-project
LANGFUSE_INIT_PROJECT_NAME="My First Project"
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-12345
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-12345
LANGFUSE_INIT_USER_EMAIL=admin@example.com

# 初始帳號密碼需至少 8 位
LANGFUSE_INIT_USER_PASSWORD=password123
